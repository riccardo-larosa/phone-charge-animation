<TaskerData sr="" dvi="1" tv="6.2.27">

	<Project sr="proj0" ve="2">
		<cdate>1740700800000</cdate>
		<id>99</id>
		<name>Charging Animation</name>
		<pids>100</pids>
		<tids>101,102</tids>
	</Project>

	<!--
		Profile: Charge Animation
		Trigger: Power source connected (any)
		Entry task: Start Charge Animation (id 101)
		Exit task:  Stop Charge Animation  (id 102)
	-->
	<Profile sr="prof100" ve="2">
		<cdate>1740700800000</cdate>
		<id>100</id>
		<mid0>101</mid0>
		<mid1>102</mid1>
		<nme>Charge Animation</nme>
		<State sr="con0" ve="2">
			<!-- 902 = Power state; arg0 val 1 = Source: Any -->
			<code>902</code>
			<Int sr="arg0" val="1"/>
		</State>
	</Profile>

	<!--
		Entry Task: Start Charge Animation
		Builds a URL with live battery stats and opens it in the browser.
	-->
	<Task sr="task101">
		<cdate>1740700800000</cdate>
		<id>101</id>
		<nme>Start Charge Animation</nme>

		<!-- Action 1 — Wait 2 seconds so battery readings stabilise -->
		<Action sr="act0" ve="7">
			<code>30</code>
			<Int sr="arg0" val="0"/>
			<Int sr="arg1" val="0"/>
			<Int sr="arg2" val="2"/>
			<Int sr="arg3" val="0"/>
			<Int sr="arg4" val="0"/>
		</Action>

		<!-- Action 2 — Set base URL (EDIT THIS to your GitHub Pages URL) -->
		<Action sr="act1" ve="7">
			<code>547</code>
			<Str sr="arg0" ve="3">%url</Str>
			<Str sr="arg1" ve="3">https://riccardo-larosa.github.io/phone-charge-animation/</Str>
			<Int sr="arg2" val="0"/>
			<Int sr="arg3" val="0"/>
		</Action>

		<!-- Action 3 — Shell: read charging current (microamps) -->
		<Action sr="act2" ve="7">
			<code>123</code>
			<Str sr="arg0" ve="3">cat /sys/class/power_supply/battery/current_now</Str>
			<Int sr="arg1" val="0"/>
			<Int sr="arg2" val="1"/>
			<Str sr="arg3" ve="3">%current</Str>
			<Str sr="arg4" ve="3"/>
			<Int sr="arg5" val="0"/>
		</Action>

		<!-- Action 4 — Shell: read battery voltage (microvolts) -->
		<Action sr="act3" ve="7">
			<code>123</code>
			<Str sr="arg0" ve="3">cat /sys/class/power_supply/battery/voltage_now</Str>
			<Int sr="arg1" val="0"/>
			<Int sr="arg2" val="1"/>
			<Str sr="arg3" ve="3">%voltage</Str>
			<Str sr="arg4" ve="3"/>
			<Int sr="arg5" val="0"/>
		</Action>

		<!-- Action 5 — Calculate watts = voltage_uV * current_uA / 1e12 -->
		<Action sr="act4" ve="7">
			<code>547</code>
			<Str sr="arg0" ve="3">%watts</Str>
			<Str sr="arg1" ve="3">%voltage * %current / 1000000000000</Str>
			<Int sr="arg2" val="1"/>
			<Int sr="arg3" val="0"/>
		</Action>

		<!-- Action 6 — Round watts to nearest integer -->
		<Action sr="act5" ve="7">
			<code>547</code>
			<Str sr="arg0" ve="3">%watts</Str>
			<Str sr="arg1" ve="3">round(%watts)</Str>
			<Int sr="arg2" val="1"/>
			<Int sr="arg3" val="0"/>
		</Action>

		<!-- Action 7 — Shell: get time-to-full in seconds from dumpsys -->
		<Action sr="act6" ve="7">
			<code>123</code>
			<Str sr="arg0" ve="3">dumpsys battery | grep -o 'time_to_full_now=[0-9]*' | cut -d= -f2</Str>
			<Int sr="arg1" val="0"/>
			<Int sr="arg2" val="1"/>
			<Str sr="arg3" ve="3">%ttf_seconds</Str>
			<Str sr="arg4" ve="3"/>
			<Int sr="arg5" val="0"/>
		</Action>

		<!-- Action 8 — Convert seconds to minutes -->
		<Action sr="act7" ve="7">
			<code>547</code>
			<Str sr="arg0" ve="3">%timeLeft</Str>
			<Str sr="arg1" ve="3">%ttf_seconds / 60</Str>
			<Int sr="arg2" val="1"/>
			<Int sr="arg3" val="0"/>
		</Action>

		<!-- Action 9 — Open animation URL with battery params
		     %BATT is a built-in Tasker variable (current battery %) -->
		<Action sr="act8" ve="7">
			<code>863</code>
			<Str sr="arg0" ve="3">%url?level=%BATT&amp;watts=%watts&amp;timeLeft=%timeLeft</Str>
		</Action>

	</Task>

	<!--
		Exit Task: Stop Charge Animation
		Kills the browser when the charger is disconnected.
	-->
	<Task sr="task102">
		<cdate>1740700800000</cdate>
		<id>102</id>
		<nme>Stop Charge Animation</nme>

		<!-- Action 1 — Kill Chrome browser -->
		<Action sr="act0" ve="7">
			<code>162</code>
			<Str sr="arg0" ve="3">com.android.chrome</Str>
		</Action>

	</Task>

</TaskerData>
